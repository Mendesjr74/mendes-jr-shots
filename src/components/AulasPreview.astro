---
import { getCollection } from 'astro:content';
const aulas = (await getCollection('aulas')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
).slice(0, 4);
---
<section id="aulas" class="relative border-t border-navy-800/60 py-24 sm:py-32">
  <div class="container-x">
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="text-xs uppercase tracking-[0.25em] text-sand-200/60">03 — Aulas</span>
        <h2 class="mt-3 font-display text-4xl sm:text-5xl">Aprender fotografando</h2>
      </div>
      <a href="/aulas" class="btn-ghost hidden sm:inline-flex">Todas as aulas →</a>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2">
      {aulas.map((aula) => (
        <a href={`/aulas/${aula.slug}`} class="card group flex items-start gap-5 p-6">
          <div class="grid h-14 w-14 shrink-0 place-items-center rounded-xl border border-navy-700 bg-navy-800/60 text-sand-100">
            {aula.data.type === 'video' ? (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="6 4 20 12 6 20 6 4"/></svg>
            ) : (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h12a4 4 0 0 1 4 4v12H8a4 4 0 0 1-4-4z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
            )}
          </div>
          <div class="flex-1">
            <p class="text-xs uppercase tracking-[0.2em] text-sand-200/60">
              {aula.data.type === 'video' ? 'Vídeo' : 'Texto'} · {aula.data.level ?? 'Geral'}
            </p>
            <h3 class="mt-2 font-display text-xl leading-tight transition group-hover:text-sand-100">{aula.data.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-sand-200/70 line-clamp-2">{aula.data.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
