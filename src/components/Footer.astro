---
import { getEntry } from 'astro:content';
const site = (await getEntry('site', 'site'))?.data;
const nome = site?.nome ?? 'Mendes Jr';
const tagline = site?.tagline ?? 'Shots & Notes';
const bio = site?.bio ?? 'Fotografar, pra mim, é uma forma de prestar atenção. Aqui você encontra uma coleção viva do que venho registrando, pensando e ensinando. Sem pressa, sem fórmula.';
const fotoPerfil = site?.fotoPerfil;
const email = site?.email ?? 'mendesjr.fortal@gmail.com';
const instagram = site?.instagram;
const youtube = site?.youtube;
const behance = site?.behance;
const year = new Date().getFullYear();
---
<section id="sobre" class="relative border-t border-navy-800/60 py-24 sm:py-28">
  <div class="container-x grid gap-12 md:grid-cols-[1fr_1fr]">
    <div>
      <span class="text-xs uppercase tracking-[0.25em] text-sand-200/60">04 — Sobre</span>
      <h2 class="mt-3 font-display text-4xl sm:text-5xl leading-tight">O fotógrafo por trás<br />das imagens.</h2>

      {fotoPerfil && (
        <div class="mt-8 overflow-hidden rounded-2xl border border-navy-800 max-w-xs aspect-[4/5]">
          <img src={fotoPerfil} alt={nome} class="h-full w-full object-cover" />
        </div>
      )}

      <p class="mt-6 max-w-md text-sand-200/80 leading-relaxed">{bio}</p>
    </div>

    <div id="contato" class="card p-8 h-fit">
      <p class="text-xs uppercase tracking-[0.25em] text-sand-200/60">Contato</p>
      <h3 class="mt-3 font-display text-2xl">Vamos conversar?</h3>
      <p class="mt-4 text-sm text-sand-200/70 leading-relaxed">
        Pra colaborações, dúvidas sobre aulas, ou só pra trocar uma ideia sobre fotografia.
      </p>
      <a href={`mailto:${email}`} class="btn-primary mt-6">{email} →</a>

      {(instagram || youtube || behance) && (
        <div class="mt-8 flex flex-wrap gap-4 text-sm text-sand-200/70">
          {instagram && <a href={instagram} target="_blank" rel="noopener" class="transition hover:text-sand-100">Instagram</a>}
          {instagram && (youtube || behance) && <span class="text-navy-700">·</span>}
          {youtube && <a href={youtube} target="_blank" rel="noopener" class="transition hover:text-sand-100">YouTube</a>}
          {youtube && behance && <span class="text-navy-700">·</span>}
          {behance && <a href={behance} target="_blank" rel="noopener" class="transition hover:text-sand-100">Behance</a>}
        </div>
      )}
    </div>
  </div>
</section>

<footer class="border-t border-navy-800/60 py-8">
  <div class="container-x flex flex-col items-center justify-between gap-3 text-xs text-sand-200/50 sm:flex-row">
    <p>© {year} {nome} · {tagline}.</p>
    <p>Feito com cuidado em Astro.</p>
  </div>
</footer>
