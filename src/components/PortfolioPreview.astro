---
import { getCollection } from 'astro:content';
const fotos = (await getCollection('portfolio')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
).slice(0, 6);
---
<section id="portfolio" class="relative py-24 sm:py-32">
  <div class="container-x">
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="text-xs uppercase tracking-[0.25em] text-sand-200/60">01 — Portfólio</span>
        <h2 class="mt-3 font-display text-4xl sm:text-5xl">Um recorte do olhar</h2>
      </div>
      <a href="/portfolio" class="btn-ghost hidden sm:inline-flex">Ver tudo →</a>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {fotos.map((foto, i) => (
        <a href={`/portfolio/${foto.slug}`} class={`card group block ${i === 0 ? 'sm:col-span-2 sm:row-span-2 aspect-square' : 'aspect-[4/5]'}`}>
          {foto.data.image ? (
            <img src={foto.data.image} alt={foto.data.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          ) : (
            <div class="h-full w-full bg-gradient-to-br from-navy-700 to-navy-900"></div>
          )}
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-transparent p-5">
            <p class="text-xs uppercase tracking-[0.2em] text-sand-200/60">{foto.data.location ?? ''}</p>
            <p class="mt-1 font-display text-lg">{foto.data.title}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
