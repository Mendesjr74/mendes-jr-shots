---
import { getCollection } from 'astro:content';
const posts = (await getCollection('historias')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
).slice(0, 3);
---
<section id="historias" class="relative border-t border-navy-800/60 py-24 sm:py-32">
  <div class="container-x">
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="text-xs uppercase tracking-[0.25em] text-sand-200/60">02 — Histórias</span>
        <h2 class="mt-3 font-display text-4xl sm:text-5xl">O que estava por trás</h2>
      </div>
      <a href="/historias" class="btn-ghost hidden sm:inline-flex">Todas →</a>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {posts.map((post) => (
        <a href={`/historias/${post.slug}`} class="card group flex flex-col p-6">
          <p class="text-xs uppercase tracking-[0.2em] text-sand-200/60">
            {new Date(post.data.date).toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' })}
          </p>
          <h3 class="mt-3 font-display text-2xl leading-tight transition group-hover:text-sand-100">{post.data.title}</h3>
          <p class="mt-4 text-sm leading-relaxed text-sand-200/70 line-clamp-3">{post.data.excerpt}</p>
          <span class="mt-6 text-sm text-sand-200/80 transition group-hover:text-sand-100">Ler →</span>
        </a>
      ))}
    </div>
  </div>
</section>
