---
import { getEntry } from 'astro:content';
const site = (await getEntry('site', 'site'))?.data;
const nome = site?.nome ?? 'Mendes Jr';
const heroTitulo = site?.heroTitulo ?? 'Luz, silêncio e o instante que fica.';
const heroSubtitulo = site?.heroSubtitulo ?? `Sou ${nome}, fotógrafo amador. Aqui compartilho meus cliques, as histórias por trás deles e aulas sobre o que aprendi no caminho — em texto e em vídeo.`;
const heroDestaque = site?.heroDestaque;
const heroDestaqueLegenda = site?.heroDestaqueLegenda ?? 'Substitua pela sua foto favorita';
---
<section class="relative">
  <div class="container-x pt-20 pb-24 sm:pt-28 sm:pb-32">
    <div class="grid items-end gap-12 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-navy-700 bg-navy-900/60 px-3 py-1 text-xs uppercase tracking-[0.2em] text-sand-200/80">
          <span class="h-1.5 w-1.5 rounded-full bg-navy-500"></span>
          Fotografia autoral
        </span>
        <h1 class="mt-6 font-display text-5xl leading-[1.05] sm:text-6xl lg:text-7xl">
          {heroTitulo}
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-sand-200/80">
          {heroSubtitulo}
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a href="#portfolio" class="btn-primary">
            Ver portfólio
            <span aria-hidden>→</span>
          </a>
          <a href="#aulas" class="btn-ghost">Explorar aulas</a>
        </div>
      </div>

      <div class="relative">
        <div class="card aspect-[4/5]">
          {heroDestaque ? (
            <img src={heroDestaque} alt={heroDestaqueLegenda} class="h-full w-full object-cover" />
          ) : (
            <>
              <div class="absolute inset-0 bg-gradient-to-br from-navy-700 via-navy-800 to-navy-950"></div>
              <div class="absolute inset-0 opacity-60 mix-blend-screen bg-[radial-gradient(circle_at_30%_20%,rgba(224,225,221,0.15),transparent_50%)]"></div>
            </>
          )}
          <div class="absolute bottom-6 left-6 right-6 flex items-end justify-between bg-gradient-to-t from-navy-950/80 to-transparent p-2 -m-2">
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-sand-200/60">Destaque</p>
              <p class="mt-1 font-display text-xl">{heroDestaqueLegenda}</p>
            </div>
            <span class="text-xs text-sand-200/60">01 / —</span>
          </div>
        </div>
        <div class="absolute -bottom-6 -left-6 hidden h-24 w-24 rounded-2xl border border-navy-700 bg-navy-900/80 backdrop-blur sm:block"></div>
      </div>
    </div>
  </div>
</section>
