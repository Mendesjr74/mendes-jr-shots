---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const fotos = await getCollection('portfolio');
  return fotos.map((foto) => ({ params: { slug: foto.slug }, props: { foto } }));
}

const { foto } = Astro.props;
const { Content } = await foto.render();
const dateFmt = new Date(foto.data.date).toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric',
});
---
<Base title={`${foto.data.title} · Portfólio`}>
  <article class="container-x py-20 sm:py-28">
    <a href="/portfolio" class="text-sm text-sand-200/60 transition hover:text-sand-100">← Portfólio</a>

    <header class="mt-8 max-w-3xl">
      <p class="text-xs uppercase tracking-[0.25em] text-sand-200/60">{foto.data.location ?? 'Foto'}</p>
      <h1 class="mt-4 font-display text-4xl leading-tight sm:text-5xl">{foto.data.title}</h1>
      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-sand-200/70">
        <span>{dateFmt}</span>
        {foto.data.camera && <span>· {foto.data.camera}</span>}
        {foto.data.lens && <span>· {foto.data.lens}</span>}
      </div>
    </header>

    <div class="mt-12 card aspect-[4/5] max-w-3xl sm:aspect-[3/2]">
      {foto.data.image ? (
        <img src={foto.data.image} alt={foto.data.title} class="h-full w-full object-cover" />
      ) : (
        <div class="h-full w-full bg-gradient-to-br from-navy-700 to-navy-900"></div>
      )}
    </div>

    <div class="prose prose-invert mt-12 max-w-2xl text-sand-200/80 leading-relaxed">
      <Content />
    </div>
  </article>
</Base>
