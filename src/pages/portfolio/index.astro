---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const fotos = (await getCollection('portfolio')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Base title="Portfólio · Mendes Jr Shots & Notes">
  <section class="container-x py-20 sm:py-28">
    <div class="mb-14">
      <a href="/" class="text-sm text-sand-200/60 transition hover:text-sand-100">← Voltar</a>
      <h1 class="mt-6 font-display text-5xl sm:text-6xl">Portfólio</h1>
      <p class="mt-4 max-w-xl text-sand-200/70">Uma coleção viva do que venho registrando.</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {fotos.map((foto) => (
        <a href={`/portfolio/${foto.slug}`} class="card group block aspect-[4/5]">
          {foto.data.image ? (
            <img src={foto.data.image} alt={foto.data.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
          ) : (
            <div class="h-full w-full bg-gradient-to-br from-navy-700 to-navy-900"></div>
          )}
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-transparent p-5">
            <p class="text-xs uppercase tracking-[0.2em] text-sand-200/60">{foto.data.location ?? ''}</p>
            <p class="mt-1 font-display text-lg">{foto.data.title}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
