---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('historias')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Base title="Histórias · Mendes Jr Shots & Notes">
  <section class="container-x py-20 sm:py-28">
    <div class="mb-14">
      <a href="/" class="text-sm text-sand-200/60 transition hover:text-sand-100">← Voltar</a>
      <h1 class="mt-6 font-display text-5xl sm:text-6xl">Histórias</h1>
      <p class="mt-4 max-w-xl text-sand-200/70">O que estava por trás de cada clique.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a href={`/historias/${post.slug}`} class="card group flex flex-col p-6">
          <p class="text-xs uppercase tracking-[0.2em] text-sand-200/60">
            {new Date(post.data.date).toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' })}
          </p>
          <h2 class="mt-3 font-display text-2xl leading-tight transition group-hover:text-sand-100">{post.data.title}</h2>
          <p class="mt-4 text-sm leading-relaxed text-sand-200/70 line-clamp-3">{post.data.excerpt}</p>
          <span class="mt-6 text-sm text-sand-200/80 transition group-hover:text-sand-100">Ler →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
